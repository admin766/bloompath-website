PORT=4173
RECIPIENT_EMAIL=info@bloompathbehavioral.com

# Set FORM_DRY_RUN=true only for local testing. Production must be false or omitted.
FORM_DRY_RUN=false

# Production on Render should use an HTTPS email API because free Render services block SMTP ports.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM="Bloompath Website <no-reply@bloompathbehavioral.com>"

# Optional SMTP fallback for paid hosts or hosts that allow outbound SMTP.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="Bloompath Website <no-reply@bloompathbehavioral.com>"
